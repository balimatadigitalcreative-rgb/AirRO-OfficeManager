# AirRO Finance API — PRODUCTION env. Copy to server/.env on the VPS and edit.
# Generate the secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

NODE_ENV=production
HOST=127.0.0.1
PORT=4000

# SQLite (simple) — file lives in server/. Use an absolute path you back up.
DATABASE_URL="file:./prod.db"
# PostgreSQL (recommended for a real business): set provider="postgresql" in
# prisma/schema.prisma, then:
# DATABASE_URL="postgresql://airro:STRONGPASS@127.0.0.1:5432/airro?schema=public"

# REQUIRED: long random secret (server refuses to start in production without it).
JWT_SECRET="PASTE_A_64_CHAR_RANDOM_HEX_HERE"
JWT_EXPIRES_IN="7d"

# Lock CORS to your domain (same-origin setup still benefits from this).
CORS_ORIGIN="https://yourdomain.com"

# Seed ONE admin account; no demo PIN users in production.
SEED_DEMO_USERS="false"
SEED_OWNER_USERNAME="owner"
SEED_OWNER_PASSWORD="CHANGE_ME_STRONG"
