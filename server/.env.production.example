# AirRO Finance API — PRODUCTION env. Copy to server/.env on the VPS and edit.
# Generate the secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

NODE_ENV=production
HOST=127.0.0.1
PORT=4000

# SQLite (simple) — file lives in server/. Use an absolute path you back up.
DATABASE_URL="file:./prod.db"
# PostgreSQL (recommended for a real business): set provider="postgresql" in
# prisma/schema.prisma, then:
# DATABASE_URL="postgresql://airro:STRONGPASS@127.0.0.1:5432/airro?schema=public"

# REQUIRED: long random secret (server refuses to start in production without it).
# Rotating this value logs EVERYONE out (all existing JWTs become invalid) — expected.
JWT_SECRET="PASTE_A_64_CHAR_RANDOM_HEX_HERE"
JWT_EXPIRES_IN="7d"

# Lock CORS to the real domain — NEVER "*" in production.
CORS_ORIGIN="https://airrooffice.com"

# Rate limiting (defaults are sane; override only if you must). Nginx is the single
# proxy in front, so the app runs with trust proxy = 1 and rate-limits on the real IP.
# LOGIN_RATE_WINDOW_MS=900000     # 15 min
# LOGIN_RATE_MAX=10               # failed logins / window / IP before 429
# FORGOT_RATE_WINDOW_MS=3600000   # 1 hour
# FORGOT_RATE_MAX=5               # forgot-password requests / hour / IP
# API_RATE_WINDOW_MS=60000        # 1 min
# API_RATE_MAX=300                # authenticated API requests / min / IP (SSE + health exempt)

# Seed ONE admin account; no demo PIN users in production.
SEED_DEMO_USERS="false"
SEED_OWNER_USERNAME="owner"
SEED_OWNER_PASSWORD="CHANGE_ME_STRONG"

# ── Offsite backups (deploy/backup-offsite.sh) ───────────────────────────────
# The DB holds salaries, NIK and BPJS data, so offsite copies MUST be encrypted.
# rclone target: "<remote>:<path>". One-time `rclone config` sets up the remote —
# see DEPLOY.md → Backup & Restore for the exact (interactive) steps.
RCLONE_REMOTE="airro-offsite:airro"
# Encryption mode A (recommended if the remote is PLAIN): gpg-encrypt each archive
# with this passphrase before upload. Generate one and store it somewhere safe
# OFFSITE too — without it the offsite copies can't be decrypted. NEVER commit it.
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"
BACKUP_PASSPHRASE="CHANGE_ME_LONG_RANDOM_AND_KEEP_A_COPY_OFFSITE"
# Mode B instead: leave BACKUP_PASSPHRASE empty and point RCLONE_REMOTE at an
# rclone `crypt` remote (rclone encrypts names + contents transparently).
# Offsite retention (days). Local keeps 14 (AIRRO_BACKUP_KEEP); offsite keeps more.
OFFSITE_KEEP_DAYS="90"
