# ── AirRO Finance API — environment config ───────────────────────────────
# Copy this file to `.env` and adjust. Never commit the real `.env`.

# Server
NODE_ENV=development
PORT=4000

# Database
# Local dev (zero setup): SQLite file relative to the prisma/ schema.
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL) — switch the datasource provider in
# prisma/schema.prisma to "postgresql" and use a URL like:
# DATABASE_URL="postgresql://user:password@localhost:5432/airro?schema=public"

# Auth — JWT signing
# Use a long random string in production, e.g. `openssl rand -hex 32`.
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# CORS — comma-separated list of allowed origins for the frontend.
# Use "*" only for local development.
CORS_ORIGIN="*"

# Seeding — the bootstrap admin account created by `npm run db:seed` (role gm,
# can administer users). For production set a STRONG password here.
SEED_OWNER_USERNAME="owner"
SEED_OWNER_PASSWORD="1234"

# Seed the extra demo role accounts (owner/hrd/finance/adminfin) with simple
# PINs. Convenient for local dev; set to "false" for any public deployment so
# only the bootstrap admin above is created.
SEED_DEMO_USERS="true"
