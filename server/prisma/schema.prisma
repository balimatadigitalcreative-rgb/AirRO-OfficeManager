// AirRO Water — finance API data model.
// Local dev uses SQLite; switch `provider` to "postgresql" for production
// (the schema is written to be portable across both).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Auth / people ────────────────────────────────────────────────────────
// Roles mirror the frontend permission matrix in finance-store.js.
// Stored as String for SQLite portability; valid values are enforced by Zod
// at the API layer: owner | gm | hrd | finance | adminfin.
model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  passwordHash String
  pin          String? // optional quick-login PIN (hashed)
  role         String   @default("finance")
  sub          String? // subtitle shown in the UI, e.g. "Finance · Keuangan"
  color        String   @default("#22A7A1")
  active       Boolean  @default(true)
  permissions  String? // JSON capability map; null = use the role's defaults
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entries   Entry[]
  setorans  Setoran[]
  transfers Transfer[]
}

// ── Cash book ────────────────────────────────────────────────────────────
// EntryType is "income" | "expense" — stored as String (SQLite-portable),
// validated by Zod at the API layer.

model Account {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("bank") // "cash" | "bank"
  bank      String   @default("")
  number    String   @default("")
  opening   Int      @default(0) // opening balance in IDR (whole rupiah)
  color     String   @default("#065489")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  entries       Entry[]
  transfersFrom Transfer[] @relation("TransferFrom")
  transfersTo   Transfer[] @relation("TransferTo")
}

model Category {
  id    String    @id @default(cuid())
  key   String    @unique
  label String
  icon  String    @default("IconDots")
  type  String // "income" | "expense"

  entries Entry[]
}

model Entry {
  id          String    @id @default(cuid())
  type        String // "income" | "expense"
  amount      Int // always positive; sign derived from `type`
  note        String    @default("")
  method      String    @default("Cash")
  date        String // YYYY-MM-DD (business date, tz-agnostic)
  time        String    @default("00:00") // HH:mm
  status      String    @default("Completed") // Completed | Pending | Failed
  createdAt   DateTime  @default(now())

  category   Category? @relation(fields: [categoryKey], references: [key])
  categoryKey String?
  account    Account?  @relation(fields: [accountId], references: [id])
  accountId  String?
  createdBy  User?     @relation(fields: [createdById], references: [id])
  createdById String?

  @@index([date])
  @@index([type])
}

model Transfer {
  id        String   @id @default(cuid())
  amount    Int
  date      String
  note      String   @default("")
  createdAt DateTime @default(now())

  from   Account @relation("TransferFrom", fields: [fromId], references: [id])
  fromId String
  to     Account @relation("TransferTo", fields: [toId], references: [id])
  toId   String
  createdBy   User?  @relation(fields: [createdById], references: [id])
  createdById String?
}

// ── Delivery setoran (per-fleet daily deposit) ───────────────────────────
model Fleet {
  id    String @id @default(cuid())
  plate String @unique

  setorans Setoran[]
}

model Setoran {
  id        String   @id @default(cuid())
  date      String // YYYY-MM-DD
  cash      Int      @default(0)
  bonPay    Int      @default(0) // receivable payments collected in the field
  expense   Int      @default(0) // field expenses paid from cash
  note      String   @default("")
  createdAt DateTime @default(now())

  fleet     Fleet?  @relation(fields: [fleetId], references: [id])
  fleetId   String?
  createdBy   User?  @relation(fields: [createdById], references: [id])
  createdById String?

  @@index([date])
}

// ── HRD / payroll ────────────────────────────────────────────────────────
model Employee {
  id         String   @id @default(cuid())
  name       String
  department String   @default("Staff")
  base       Int      @default(0) // base salary (IDR)
  allowance  Int      @default(0) // "Tunjangan lain" — legacy catch-all, still counted
  // Structured monthly allowances (all add to gross earnings). tjBpjs* are cash
  // allowances GIVEN to the employee — NOT the statutory BPJS iuran, which the
  // payroll engine computes separately. See finance-hrd.js compute().
  tjKinerja    Int    @default(0) // Tj. Kinerja
  tjProfesi    Int    @default(0) // Tj. Profesi
  tjRumahDinas Int    @default(0) // Tj. Rumah Dinas
  tjBpjsKes    Int    @default(0) // Tj. BPJS Kesehatan (allowance to employee)
  tjBpjsTk     Int    @default(0) // Tj. BPJS Ketenagakerjaan (allowance to employee)
  risk       String   @default("Low") // JKK occupational-risk class
  jp         Boolean  @default(true) // enrolled in JP (pension)
  religion   String   @default("Islam")
  joinedDate String? // YYYY-MM-DD, for THR proration
  // Offboarding. `active` is DERIVED: active = (status === "active"). Keep both in
  // sync (never contradictory). Non-active statuses exclude the employee from
  // active payroll/headcount but keep the record for history.
  status           String  @default("active") // active | resigned | terminated | dishonorable | absconded | contract_ended | retired
  separationDate   String? // YYYY-MM-DD, last working day (effective date)
  separationReason String?
  separationNote   String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  // Extended HR profile (all optional / defaulted → old rows stay valid).
  nip             String?  @unique // auto-generated <OFFICE>-YY-NNN, see employee.service
  noSurat         String? // No Surat (assignment/decree letter no.)
  noKk            String? // No KK (family card)
  noBpjsKes       String? // BPJS Kesehatan no.
  noBpjsTk        String? // BPJS Ketenagakerjaan no.
  office          String   @default("AIRRO") // posisi kantor: AIRRO | NSN | MFG
  contractStart   String? // YYYY-MM-DD
  contractEnd     String? // YYYY-MM-DD (for contract-expiry alerts later)
  birthPlace      String? // TTL — place of birth
  birthDate       String? // YYYY-MM-DD — date of birth
  addressKtp      String?
  addressDomisili String?
  maritalStatus   String   @default("TK") // TK | K | Cerai

  cashbons Cashbon[]
}

// ── Kasbon (employee cash advance / loan → auto salary deduction) ─────────
model Cashbon {
  id           String   @id @default(cuid())
  employeeId   String
  amount       Int // nominal kasbon (IDR)
  date         String // YYYY-MM-DD pengajuan
  note         String   @default("")
  installments Int      @default(1) // dicicil berapa bulan (legacy; per-cycle rule deducts in full)
  status       String   @default("active") // active | paid | cancelled
  cycleAnchor  String? // payroll cycle this kasbon belongs to (cutoff date YYYY-MM-15)
  createdAt    DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

// ── NIP allocation ledger ────────────────────────────────────────────────
// One row per issued NIP. The unique constraints make sequence allocation
// race-safe (concurrent requests can't claim the same office+year+seq). This
// is the source of truth for NIP counters even though employee records
// themselves live in the shared /state document store, not in `Employee`.
model EmployeeNip {
  id        String   @id @default(cuid())
  nip       String   @unique // <OFFICE>-YY-NNN
  office    String // AIRRO | NSN | MFG
  year      String // 2-digit, e.g. "26"
  seq       Int // running counter within office+year, starts at 1
  createdAt DateTime @default(now())

  @@unique([office, year, seq])
  @@index([office, year])
}

// ── Key/value settings (alert thresholds, HR rates, budget, etc.) ────────
model Setting {
  key   String @id
  value String // JSON-encoded value
}

// ── Shared app state ─────────────────────────────────────────────────────
// Server-side mirror of the app's data slices (entries, setoran, staff,
// categories, accounts, etc.), one JSON document per key, shared across all
// users so everyone reads/writes the same data. The frontend cloud adapter
// mirrors its localStorage here.
model Document {
  key       String   @id
  value     String // JSON blob (the localStorage value, verbatim)
  updatedAt DateTime @updatedAt
}
