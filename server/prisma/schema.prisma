// AirRO Water — finance API data model.
// Local dev uses SQLite; switch `provider` to "postgresql" for production
// (the schema is written to be portable across both).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Auth / people ────────────────────────────────────────────────────────
// Roles mirror the frontend permission matrix in finance-store.js.
// Stored as String for SQLite portability; valid values are enforced by Zod
// at the API layer: owner | gm | hrd | finance | adminfin.
model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  passwordHash String
  pin          String? // optional quick-login PIN (hashed)
  mustChangePassword Boolean @default(false) // force a password change on next login
  role         String   @default("finance")
  sub          String? // subtitle shown in the UI, e.g. "Finance · Keuangan"
  color        String   @default("#22A7A1")
  active       Boolean  @default(true)
  permissions  String? // JSON capability map; null = use the role's defaults
  fleetScope   String   @default("all") // distribusi fleet access: "all" or a JSON array of fleet names
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entries   Entry[]
  setorans  Setoran[]
  transfers Transfer[]
}

// ── Roles (editable by owner/GM; seeded from config/permissions.js) ───────
// A role is data, not a constant: { id, name, color, permissions(JSON) }. Built-in
// roles (owner/gm/hrd/finance/adminfin) are seeded at startup and can't be deleted.
model Role {
  id          String   @id // role key, e.g. "owner", "kasir"
  name        String
  color       String   @default("#22A7A1")
  permissions String // JSON capability map { cap: bool }
  builtin     Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())
}

// ── Cash book ────────────────────────────────────────────────────────────
// EntryType is "income" | "expense" — stored as String (SQLite-portable),
// validated by Zod at the API layer.

model Account {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("bank") // "cash" | "bank"
  bank      String   @default("")
  number    String   @default("")
  opening   Int      @default(0) // opening balance in IDR (whole rupiah)
  color     String   @default("#065489")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  entries       Entry[]
  transfersFrom Transfer[] @relation("TransferFrom")
  transfersTo   Transfer[] @relation("TransferTo")
}

model Category {
  id    String    @id @default(cuid())
  key   String    @unique
  label String
  icon  String    @default("IconDots")
  type  String // "income" | "expense"

  entries Entry[]
}

model Entry {
  id          String    @id @default(cuid())
  type        String // "income" | "expense"
  amount      Int // always positive; sign derived from `type`
  note        String    @default("")
  method      String    @default("Cash")
  date        String // YYYY-MM-DD (business date, tz-agnostic)
  time        String    @default("00:00") // HH:mm
  status      String    @default("Completed") // Completed | Pending | Failed
  gallonQty   Int       @default(0) // >0 on a "Pembelian Galon" expense → syncs a purchase movement
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt @default(now()) // bumped on every change (incremental sync)

  // The frontend cash book stores category/account as free-form keys resolved
  // against its own (blob-backed) category & account lists — which may include
  // user-created categories that never reach the Category table. So these are
  // PLAIN columns (like Setoran.armada), NOT foreign keys, to avoid rejecting a
  // valid entry whose category/account only exists client-side.
  category   String? // frontend category key (e.g. "Refill", "Supplies")
  acct       String? // frontend account id (e.g. "cash", "bca")
  proof      String? // attached proof image (data URL / path)
  // Extra frontend-specific tags (custPay/party/payroll/thr/orientation), JSON.
  // Kept opaque here so new tags never require a schema change.
  meta       String?

  // Legacy relational columns kept for backward-compatibility; unused by the
  // per-record cash-book path above (always null there).
  categoryRel Category? @relation(fields: [categoryKey], references: [key])
  categoryKey String?
  account    Account?  @relation(fields: [accountId], references: [id])
  accountId  String?
  createdBy  User?     @relation(fields: [createdById], references: [id])
  createdById String?
  // Creator snapshot captured AT INPUT TIME (name + role as they were then). Kept
  // as plain columns — not derived from the live User relation — so the "input by"
  // label is a stable historical record that never changes if the user is later
  // renamed or moved to a different role.
  createdByName String?
  createdByRole String?

  @@index([date])
  @@index([type])
  @@index([updatedAt])
}

model Transfer {
  id        String   @id @default(cuid())
  amount    Int
  date      String
  note      String   @default("")
  createdAt DateTime @default(now())

  from   Account @relation("TransferFrom", fields: [fromId], references: [id])
  fromId String
  to     Account @relation("TransferTo", fields: [toId], references: [id])
  toId   String
  createdBy   User?  @relation(fields: [createdById], references: [id])
  createdById String?
}

// ── Delivery setoran (per-fleet daily deposit) ───────────────────────────
model Fleet {
  id    String @id @default(cuid())
  plate String @unique

  setorans Setoran[]
}

model Setoran {
  id        String   @id @default(cuid())
  date      String // YYYY-MM-DD
  armada    String   @default("") // fleet plate string (the frontend's per-armada key)
  galon     Int      @default(0) // gallons sold that day (drives manufacturing cost)
  cash      Int      @default(0)
  bon       Int      @default(0) // credit/receivable sales booked (not yet collected)
  bonPay    Int      @default(0) // receivable payments collected in the field
  expense   Int      @default(0) // field expenses paid from cash
  note      String   @default("")
  proof     String? // attached proof image (data URL / path)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // bumped on every change (supports incremental sync)

  fleet     Fleet?  @relation(fields: [fleetId], references: [id])
  fleetId   String?
  createdBy   User?  @relation(fields: [createdById], references: [id])
  createdById String?

  @@index([date])
  @@index([updatedAt])
}

// ── HRD / payroll ────────────────────────────────────────────────────────
model Employee {
  id         String   @id @default(cuid())
  name       String
  department String   @default("Staff")
  base       Int      @default(0) // base salary (IDR)
  allowance  Int      @default(0) // "Tunjangan lain" — legacy catch-all, still counted
  // Structured monthly allowances (all add to gross earnings). tjBpjs* are cash
  // allowances GIVEN to the employee — NOT the statutory BPJS iuran, which the
  // payroll engine computes separately. See finance-hrd.js compute().
  tjKinerja    Int    @default(0) // Tj. Kinerja
  tjProfesi    Int    @default(0) // Tj. Profesi
  tjRumahDinas Int    @default(0) // Tj. Rumah Dinas
  tjBpjsKes    Int    @default(0) // Tj. BPJS Kesehatan (allowance to employee)
  tjBpjsTk     Int    @default(0) // Tj. BPJS Ketenagakerjaan (allowance to employee)
  risk       String   @default("Low") // JKK occupational-risk class
  jp         Boolean  @default(true) // enrolled in JP (pension)
  religion   String   @default("Islam")
  joinedDate String? // YYYY-MM-DD, for THR proration
  // Offboarding. `active` is DERIVED: active = (status === "active"). Keep both in
  // sync (never contradictory). Non-active statuses exclude the employee from
  // active payroll/headcount but keep the record for history.
  status           String  @default("active") // active | resigned | terminated | dishonorable | absconded | contract_ended | retired | orientation_failed
  separationDate   String? // YYYY-MM-DD, last working day (effective date)
  separationReason String?
  separationNote   String?
  // Employment-lifecycle stage — SEPARATE from `status` (which is still-working /
  // how-they-left). New hires start in orientation and are excluded from monthly
  // payroll (paid a lump sum instead) until promoted to probation/permanent.
  stage      String   @default("orientation") // orientation | dw | probation | permanent | contract
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  // Extended HR profile (all optional / defaulted → old rows stay valid).
  nip             String?  @unique // auto-generated <OFFICE>-YY-NNN, see employee.service
  noSurat         String? // No Surat (assignment/decree letter no.)
  noKk            String? // No KK (family card)
  noBpjsKes       String? // BPJS Kesehatan no. (identity — separate from enrollment)
  noBpjsTk        String? // BPJS Ketenagakerjaan no. (identity — separate from enrollment)
  // BPJS iuran ENROLLMENT — iuran (kes/jht/jp/jkk/jkm) is deducted only once enrolled,
  // from the start date. Separate from the noBpjs* numbers and the tjBpjs* cash
  // allowances. Legacy rows (null) are treated as enrolled-full by the payroll engine.
  bpjsKesEnrolled Boolean @default(false)
  bpjsKesStart    String? // YYYY-MM-DD
  bpjsTkEnrolled  Boolean @default(false)
  bpjsTkStart     String? // YYYY-MM-DD
  office          String   @default("AIRRO") // posisi kantor: AIRRO | NSN | MFG
  contractStart   String? // YYYY-MM-DD
  contractEnd     String? // YYYY-MM-DD (for contract-expiry alerts later)
  birthPlace      String? // TTL — place of birth
  birthDate       String? // YYYY-MM-DD — date of birth
  addressKtp      String?
  addressDomisili String?
  maritalStatus   String   @default("TK") // TK | K | Cerai

  // Full frontend staff object (JSON), verbatim. The structured columns above are a
  // server-side PROJECTION (payroll engine + queries + NIP); `data` is the faithful
  // source of truth so frontend-only fields (pos, pph, offDays, deductions[], nik,
  // bank, account, phone, employment-type `status`, inline `orientation`, …) are
  // never dropped on the round-trip. Same idea as a per-record document.
  data      String?
  updatedAt DateTime @updatedAt @default(now()) // bumped on every change (incremental sync)
  // Creator snapshot captured AT INPUT TIME (name + role as they were then). Plain
  // columns — authoritative, server-stamped from the token, never from the client
  // `data` blob — so "added by" is a stable historical record. createdById is the
  // stable identity (drives per-user "My Activity"); name/role are the historical
  // display. (Employee has no createdBy FK relation; the snapshot can't be forged.)
  createdById   String?
  createdByName String?
  createdByRole String?

  cashbons          Cashbon[]
  trainings         Training[]
  calendarEvents    CalendarEvent[]
  orientation       Orientation?
  orientationDays   OrientationAttendance[]
}

// ── New-hire orientation (paid daily, lump-sum at the end; separate from payroll) ──
model Orientation {
  id           String   @id @default(cuid())
  employeeId   String   @unique
  startDate    String // YYYY-MM-DD
  durationDays Int      @default(7)
  dailyWage    Int      @default(0)
  endDate      String? // derived = startDate + durationDays
  outcome      String   @default("pending") // pending | passed | failed
  paid         Boolean  @default(false)
  paidAt       String?
  note         String   @default("")
  createdAt    DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

// ── Orientation/DW daily attendance (drives the lump-sum wage) ────────────
// Late status & lateMinutes are derived from checkIn vs rates.lateStart at the
// app layer and stored here for audit. overtimeHours reuses the payroll OT rate.
model OrientationAttendance {
  id            String   @id @default(cuid())
  employeeId    String
  date          String // YYYY-MM-DD
  checkIn       String? // HH:MM (null = absent)
  status        String   @default("present") // present | late | absent
  lateMinutes   Int      @default(0)
  overtimeHours Float    @default(0)
  note          String   @default("")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId])
}

// ── Unified HR calendar (holidays, leave, permits) ───────────────────────
model CalendarEvent {
  id         String   @id @default(cuid())
  type       String // holiday | leave | permit
  title      String
  employeeId String? // null for national / religious holidays
  startDate  String // YYYY-MM-DD
  endDate    String?
  note       String   @default("")
  sourceId   String? // originating approval request id (dedupe auto-created leave)
  createdAt  DateTime @default(now())

  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([startDate])
}

// ── Employee training / development records ──────────────────────────────
model Training {
  id         String   @id @default(cuid())
  employeeId String
  title      String
  provider   String   @default("")
  startDate  String // YYYY-MM-DD
  endDate    String?
  cost       Int      @default(0)
  status     String   @default("planned") // planned | ongoing | done
  note       String   @default("")
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

// ── Kasbon (employee cash advance / loan → auto salary deduction) ─────────
model Cashbon {
  id           String   @id @default(cuid())
  employeeId   String
  amount       Int // nominal kasbon (IDR)
  date         String // YYYY-MM-DD tanggal pengajuan (requestDate)
  disbursedDate String? // YYYY-MM-DD tanggal DIBERIKAN/dicairkan — set on ACC; drives the deduction cycle
  note         String   @default("")
  installments Int      @default(1) // dicicil berapa bulan (legacy; per-cycle rule deducts in full)
  status       String   @default("pending") // pending | approved | rejected | paid | cancelled (legacy: active)
  cycleAnchor  String? // payroll cycle this kasbon belongs to (cutoff date YYYY-MM-15)
  // Approval trail (requestedBy/requestedAt/approvedBy/decidedAt/rejectReason), JSON.
  data      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now()) // bumped on every change (incremental sync)
  // Creator snapshot at request time (name + role then) — server-stamped from the
  // token, never the client body/trail, so "diajukan oleh" is historical + unforgeable.
  // createdById is the stable identity (drives per-user "My Activity").
  createdById   String?
  createdByName String?
  createdByRole String?

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([updatedAt])
}

// ── Approvals (leave / deduction / reimbursement / purchase / custom) ─────
// Submitted by staff, decided by GM/Finance/HRD. Per-record so concurrent
// submit/approve never clobber each other. The full frontend request object lives
// in `data` (JSON); type/status are projected columns for filtering.
model Approval {
  id        String   @id @default(cuid())
  type      String   @default("custom") // leave | deduction | reimburse | purchase | custom
  status    String   @default("pending") // pending | approved | rejected
  data      String? // full frontend approval object (verbatim)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
  // Creator snapshot at submit time (name + role then) — server-stamped from the
  // token, never the client body, so "diajukan oleh" is historical + unforgeable.
  // createdById is the stable identity (drives per-user "My Activity").
  createdById   String?
  createdByName String?
  createdByRole String?

  @@index([status])
  @@index([updatedAt])
}

// Forgot-password request (no email infra — request-to-admin flow). Created UNAUTHENTICATED
// from the login screen; owner/HRD (user-management) sees it in Requests + AlertBell, resets
// the password (temporary + mustChangePassword) using the existing admin flow, then marks it
// handled. A dedicated model (NOT Approval) because it is created without a login, is gated by
// user-management rather than the `approvals` cap, and needs none of Approval's creator/data.
model PasswordResetRequest {
  id            String    @id @default(cuid())
  username      String                             // requested username (lowercased); may or may not exist
  note          String    @default("")
  status        String    @default("pending")      // pending | selesai | ditolak
  requestedAt   DateTime  @default(now())
  handledById   String?
  handledByName String?
  handledAt     DateTime?

  @@index([status])
  @@index([requestedAt])
}

// ── NIP allocation ledger ────────────────────────────────────────────────
// One row per issued NIP. The unique constraints make sequence allocation
// race-safe (concurrent requests can't claim the same office+year+seq). This
// is the source of truth for NIP counters even though employee records
// themselves live in the shared /state document store, not in `Employee`.
model EmployeeNip {
  id        String   @id @default(cuid())
  nip       String   @unique // <OFFICE>-YY-NNN
  office    String // AIRRO | NSN | MFG
  year      String // 2-digit, e.g. "26"
  seq       Int // running counter within office+year, starts at 1
  createdAt DateTime @default(now())

  @@unique([office, year, seq])
  @@index([office, year])
}

// ── Key/value settings (alert thresholds, HR rates, budget, etc.) ────────
model Setting {
  key   String @id
  value String // JSON-encoded value
}

// ── Shared app state ─────────────────────────────────────────────────────
// Server-side mirror of the app's data slices (entries, setoran, staff,
// categories, accounts, etc.), one JSON document per key, shared across all
// users so everyone reads/writes the same data. The frontend cloud adapter
// mirrors its localStorage here.
model Document {
  key       String   @id
  value     String // JSON blob (the localStorage value, verbatim)
  updatedAt DateTime @updatedAt
}

// ════════════════════════════════════════════════════════════════════════
// DISTRIBUSI — a SEPARATE module from the AirRO cash book. Distribution sales
// never post to the AirRO Entry/cash-flow tables. Field names are camelCase
// (repo convention); the design-handoff snake_case names map 1:1 (master_price
// → masterPrice, unit_price_locked → unitPriceLocked, txn_date → txnDate, …).
// created_by / actor_* keep a name+role snapshot too, matching the app-wide
// creator-attribution pattern (historical, server-stamped, unforgeable).
// ════════════════════════════════════════════════════════════════════════

model Customer {
  id            String   @id @default(cuid())
  code          String?  @unique                  // human-readable running id (C-0001). Server-allocated,
                                                   // stable, never reused. Nullable only for the migration
                                                   // window (backfilled once); every new customer gets one.
  name          String
  phone         String   @default("")
  type          String   @default("reguler") // CustomerType id (seed ids: reguler|kos|cafe|bulk)
  masterPrice   Int      @default(0)          // master_price (IDR per unit)
  deliveryDays  String   @default("[]")       // JSON array of day codes, e.g. ["Sen","Rab","Jum"]
  armada        String   @default("")         // delivery fleet plate (reuses the Setoran fleet list)
  reminder      String   @default("")         // JSON billing-reminder settings ({enabled,dueDay,weekday,overdueDays,gallonThreshold,bonThreshold})
  lat           Float?                          // GPS latitude  (set from the field or pasted)
  lng           Float?                          // GPS longitude
  mapsUrl       String   @default("")          // Google Maps link (pasted share link, or built ?q=lat,lng)
  address       String   @default("")          // free-text address (optional)
  locationSetAt DateTime?                       // when the coordinates were last set
  locationSetByName String?                     // who set them (accountability trail)
  locationAccuracy Float?                        // GPS accuracy in metres (position.coords.accuracy); null = pasted/unknown
  locationPhotoId  String?                       // Attachment.id of the location photo (bytes fetched lazily, never inline)
  locationPhotoAt  DateTime?                     // when the photo was taken/uploaded
  locationPhotoByName String?                    // who took it
  active        Boolean  @default(true)         // false = deactivated (hidden from active list + new txn/delivery, history kept)
  deactivatedAt DateTime?
  deactivatedByName String?
  createdById   String?                        // created_by (identity)
  createdByName String?
  createdByRole String?
  createdAt     DateTime @default(now())

  transactions DistTransaction[]
  priceHistory PriceHistory[]
  deliveries   Delivery[]

  @@index([type])
}

// Append-only counter for customer codes (C-0001…). A dedicated table (like EmployeeNip) keeps
// the sequence MONOTONIC and race-safe: rows are never deleted, so a code is never reused when a
// customer is deactivated/deleted; concurrent creates can't claim the same seq (unique → retry).
model CustomerCode {
  id        String   @id @default(cuid())
  code      String   @unique
  seq       Int      @unique
  createdAt DateTime @default(now())
}

// Editable customer-type dictionary (id + label so a rename never orphans customers).
// Seeded with reguler/kos/cafe/bulk (ids match the legacy string values → back-compat).
model CustomerType {
  id        String   @id @default(cuid())
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// Append-only ledger of master-price changes (never updated/deleted).
model PriceHistory {
  id            String   @id @default(cuid())
  customerId    String
  oldPrice      Int
  newPrice      Int
  changedById   String?                        // changed_by
  changedByName String?
  changedByRole String?
  changedAt     DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

// Distribution sales. IMMUTABLE — never updated or deleted; mistakes are fixed
// by appending a Correction. The unit price is LOCKED server-side from the
// customer's master_price at input time and amount is computed on the server.
model DistTransaction {
  id              String   @id @default(cuid())
  customerId      String
  fleetId         String   @default("")         // fleet scope — copied from the customer's armada at input time (immutable)
  qty             Int
  unitPriceLocked Int                          // unit_price_locked
  amount          Int                          // qty * unitPriceLocked (server-computed)
  method          String   @default("lunas")   // lunas | bon | pelunasan
  note            String   @default("")
  txnDate         String                        // txn_date (YYYY-MM-DD)
  actorId         String?                       // actor_id
  actorRole       String?                       // actor_role (at input time)
  actorName       String?
  deliveryRunId   String?                       // the delivery run (rit) this sale belongs to — set if a run was open
  legacy          Boolean  @default(false)       // imported historical row — ARCHIVE ONLY: excluded from every
                                                 // KPI / cash / gallon / receivable aggregate; never writes a GallonMovement
  importBatchId   String?                        // groups the rows of one legacy import (for undo)
  createdAt       DateTime @default(now())

  customer    Customer     @relation(fields: [customerId], references: [id])
  corrections Correction[]

  @@index([txnDate])
  @@index([customerId])
  @@index([fleetId])
  @@index([deliveryRunId])
  @@index([importBatchId])
}

// Delivery run (rit) — one trip of a fleet: gallons loaded out, then full/empty returned,
// with automatic reconciliation (expected remaining = loaded − sold vs actually returned).
// It is a TRUCK-level tally + control layer; gallon STOCK stays driven by the per-customer
// delivery_out/return_in movements (single source), so no second gallon number is created.
model DeliveryRun {
  id                   String   @id @default(cuid())
  date                 String                          // YYYY-MM-DD
  fleetId              String
  runNo                Int                             // 1, 2, 3 … per fleet per day
  gallonsOut           Int      @default(0)            // full gallons loaded at departure (MUAT)
  gallonsFullReturned  Int      @default(0)            // full (unsold) gallons brought back (TUTUP)
  gallonsEmptyReturned Int      @default(0)            // empty gallons brought back from customers (TUTUP)
  status               String   @default("open")       // open | closed
  diffReason           String   @default("")           // mandatory when the reconciliation difference ≠ 0
  note                 String   @default("")
  openedById   String?
  openedByName String?
  openedAt     DateTime @default(now())
  closedById   String?
  closedByName String?
  closedAt     DateTime?

  @@unique([date, fleetId, runNo])
  @@index([fleetId, status])
  @@index([date, fleetId])
}

// Delivery board — one row per stop, per fleet, per date. `jadwal` rows are generated
// (idempotent) from a customer's deliveryDays; `tambahan` rows are added by an admin.
model Delivery {
  id            String   @id @default(cuid())
  date          String                          // YYYY-MM-DD
  fleetId       String   @default("")           // armada — copied from the customer at creation
  customerId    String
  source        String   @default("jadwal")     // jadwal | tambahan
  seq           Int      @default(0)            // route order
  status        String   @default("pending")    // pending | terkirim | batal | ditunda
  qty           Int?                             // optional planned qty
  note          String   @default("")
  pendingReason String   @default("")            // why NOT delivered, recorded at day-closeout
  transactionId String?                          // set when a txn is created from this stop
  createdById   String?
  createdByName String?
  createdAt     DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([date, customerId, source])           // idempotent generation (1 jadwal + 1 tambahan / cust / day)
  @@index([date, fleetId])
}

// Daily delivery closeout — a helper closes the day for (date, armada) with a report.
// One per (date, fleetId). Undelivered stops carry their reason on Delivery.pendingReason
// and are moved to status 'ditunda' at closeout (kept, not lost).
model DeliveryCloseout {
  id           String   @id @default(cuid())
  date         String
  fleetId      String   @default("")
  closedById   String?
  closedByName String?
  closedAt     DateTime @default(now())
  generalNote  String   @default("")
  delivered    Int      @default(0)
  pending      Int      @default(0)
  cancelled    Int      @default(0)

  @@unique([date, fleetId])
  @@index([date])
}

// Append-only corrections against a transaction (the transaction itself is never
// mutated). `reason` is required; `byStaff` flags a correction made by a
// staff-level actor (distribusi only, no owner caps).
//
// Two kinds: `manual` (a hand-written koreksi, deltaAmount 0) and `price` (a master-
// price change applied retroactively to an old transaction — deltaAmount = (new−old)×qty,
// grouped by batchId so the whole event can be reversed). Effective/reported amount of
// a transaction = amount + Σ(active price deltas). `active` flips to false when a batch
// is cancelled — the original transaction is NEVER touched.
model Correction {
  id            String   @id @default(cuid())
  transactionId String
  reason        String                          // required
  kind          String   @default("manual")     // manual | price
  deltaAmount   Int      @default(0)             // numeric effect for price adjustments
  batchId       String?                          // groups one price-change event's adjustments
  active        Boolean  @default(true)          // false once the batch is cancelled/reversed
  oldValue      String?                          // old_value (JSON string)
  newValue      String?                          // new_value (JSON string)
  actorId       String?
  actorRole     String?
  actorName     String?
  byStaff       Boolean  @default(false)
  createdAt     DateTime @default(now())

  transaction DistTransaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
  @@index([batchId])
}

// Append-only gallon-stock ledger (loan/exchange model) — the SINGLE source of truth
// for all stock numbers (customer balances + depot). Never mutated; a mistake is fixed
// by appending a `correction`. A purchase movement mirrors a cash-flow expense entry and
// is deactivated (active=false) if that entry is deleted, so stock never dangles.
model GallonMovement {
  id            String   @id @default(cuid())
  type          String                          // purchase | delivery_out | return_in | correction | opening | damage | loss
  qty           Int                             // positive; a correction's qty is a signed delta
  customerId    String?                         // set for delivery_out / return_in / customer correction
  transactionId String?                         // the DistTransaction that produced a delivery/return
  cashEntryId   String?                         // the cash-flow Entry a purchase mirrors
  fleetId       String   @default("")           // fleet scope ('' = global/depot)
  active        Boolean  @default(true)         // false when a linked cash purchase is removed
  note          String   @default("")
  proof         String?                         // JSON proof-ref for a damage/loss report (evidence photo)
  actorId       String?
  actorRole     String?
  actorName     String?
  createdAt     DateTime @default(now())

  @@index([customerId])
  @@index([cashEntryId])
  @@index([type])
  @@index([fleetId])
}

// Immutable, append-only audit trail for every distribusi write.
model DistAuditLog {
  id        String   @id @default(cuid())
  kind      String                              // koreksi | harga | input | impor | pelanggan
  title     String
  detail    String   @default("")
  fleetId    String   @default("") // fleet scope of the event ("" = global/cross-fleet)
  actorId    String?
  actorRole  String?
  actorName  String?
  actorStaff Boolean  @default(false) // actor was a distribusi-staff (no owner caps)
  createdAt  DateTime @default(now())

  @@index([kind])
  @@index([createdAt])
}

// Customer invoice / nota (a DOCUMENT — never mutates transactions). Snapshots the
// billed items + totals at issue time so the archived invoice stays stable even if
// later corrections/price changes happen. Kept per-customer for archive & audit.
model DistInvoice {
  id            String   @id @default(cuid())
  number        String   @unique                 // INV-YYYYMMDD-xxxx
  customerId    String
  fleetId       String   @default("")
  issueDate     String                            // YYYY-MM-DD
  dueDate       String   @default("")             // YYYY-MM-DD (from reminder setting or explicit)
  items         String   @default("[]")           // JSON snapshot: [{txnId,date,qty,unitPrice,amount,method}]
  total         Int      @default(0)              // Σ billed items
  sisaBon       Int      @default(0)              // outstanding bon snapshot at issue
  note          String   @default("")
  createdById   String?
  createdByName String?
  createdByRole String?
  createdAt     DateTime @default(now())

  @@index([customerId])
  @@index([fleetId])
}

// Proof photos / PDFs stored OUT of the record payload. Records (Entry/Setoran) keep
// only a tiny reference ({"ref":"<id>","name":..,"isImg":..}) in their `proof` column,
// so hydrate/login never drags the base64 bytes. The bytes live here and are fetched
// lazily (GET /attachments/:id) only when a proof is actually opened.
model Attachment {
  id          String   @id @default(cuid())
  name        String   @default("")
  mime        String   @default("")
  isImg       Boolean  @default(true)
  data        String                              // base64 data URL (the actual bytes)
  size        Int      @default(0)                // char length of `data` (rough bytes)
  createdById String?
  createdAt   DateTime @default(now())

  @@index([createdById])
}

// ── GUDANG (warehouse inventory) ─────────────────────────────────────────────
// A generic, ledger-based inventory: one InventoryItem per goods type, its stock is
// ALWAYS the sum of its StockMovement rows (append-only) — never a stored number. New
// item types are added just by inserting a row. GALON is the one exception: its stock is
// read from the existing GallonMovement ledger (Distribusi > Stok Galon) so there is only
// ONE authoritative gallon number; the Galon item here carries only its buffer threshold.
model InventoryItem {
  id        String   @id                          // stable slug (galon|sticker|tutup|segel) or a cuid for custom
  name      String
  kind      String                                // galon | sticker | tutup | segel | lainnya
  unit      String   @default("pcs")              // pcs | galon | roll | …
  bufferMin Int      @default(0)                  // safe-stock threshold; stock ≤ bufferMin (and >0) ⇒ "perlu restock"
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  movements StockMovement[]
  @@index([kind])
}

// Append-only stock ledger for every non-galon item. Directional types (in/purchase/opening
// add; out/damage/loss/sale subtract) store a positive qty; `correction` stores a signed
// delta. Each row carries who/when/why — the ledger IS the audit trail.
model StockMovement {
  id        String   @id @default(cuid())
  itemId    String
  type      String                                // opening | purchase | in | out | damage | loss | sale | correction
  qty       Int                                   // positive for directional types; signed delta for correction
  amount    Int?                                  // money for a 'sale' (total Rp); null otherwise
  method    String?                               // payment method for a 'sale' (Cash/Transfer/…)
  fleetId   String   @default("")                 // optional fleet scope ('' = global)
  refId     String?                               // optional link to another record (the source GallonMovement, …)
  reason    String   @default("")
  actorId   String?
  actorName String?
  actorRole String?
  createdAt DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id])
  @@index([itemId])
  @@index([type])
}

// Daily warehouse closeout (opname) — a stock-take + day report. The officer confirms or
// inputs a PHYSICAL count per item; any gap vs the system (ledger) number is recorded here AND
// posted as a correction (never a silent overwrite). One per date; supervisors read the report.
model WarehouseCloseout {
  id           String   @id @default(cuid())
  date         String   @unique                       // YYYY-MM-DD
  closedById   String?
  closedByName String?
  closedAt     DateTime @default(now())
  items        String   @default("[]")                // JSON: [{itemId,name,unit,kind,system,physical,diff,reason}]
  summary      String   @default("{}")                // JSON day summary (runs out/in, damage/loss, restock, rusak sales)
  note         String   @default("")                  // kendala / catatan
  diffCount    Int      @default(0)                   // items with an opname difference (quick "selisih menonjol")
}
